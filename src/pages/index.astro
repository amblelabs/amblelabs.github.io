---
import { Image } from "astro:assets";
import Icon from "../components/Icon.astro";
import Logo from "../components/Logo.astro";

import ambleLogoSvg from "../assets/amblelabs_icon.svg";
import ambleLogoGif from "../assets/amblelabs_icon.gif";

import "../assets/style.css";
import Footer from "../components/Footer.astro";
import siteData from "../data/site.json";

const { members, mods, wikis, links, donations } = siteData;
const allMembers = [
    { label: "Developers", list: members.developers },
    { label: "Artists", list: members.artists },
    { label: "Others", list: members.others },
    { label: "Junior Developers", list: members.junior_developers },
];

import ASCII from "../data/ascii.txt?raw";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>AmbleLabs</title>
        <meta content="AmbleLabs" property="og:title" />
        <meta content={siteData.tagline} property="og:description" />
        <meta content="https://amblelabs.dev" property="og:url" />
        <meta content={ambleLogoGif.src} property="og:image" />
        <meta content={siteData.tagline} name="description" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="icon" type="image/svg" href={ambleLogoSvg.src} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <meta content="#FF9100" data-react-helmet="true" name="theme-color" />
    </head>

    <body>
        <!-- Noise grain overlay -->
        <div class="noise-overlay" aria-hidden="true"></div>
        <!-- Scan line -->
        <div class="scan-line" aria-hidden="true"></div>

        <!-- Background effects -->
        <div class="bg-effects" aria-hidden="true">
            <div class="bg-gradient"></div>
            <div class="bg-grid"></div>
            <div class="bg-vignette"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
        </div>

        <!-- Navigation -->
        <nav class="nav" id="mainNav">
            <a href="#hero" class="nav-logo">
                <Image
                    src={ambleLogoSvg}
                    alt="AmbleLabs"
                    class="nav-logo-icon"
                    loading="eager"
                />
                <span class="nav-logo-text">AmbleLabs</span>
            </a>

            <ul class="nav-links">
                <li>
                    <a
                        href="#about"
                        class="nav-link active"
                        data-section="about"
                        ><span class="nav-num">01</span> About</a
                    >
                </li>
                <li>
                    <a href="#team" class="nav-link" data-section="team"
                        ><span class="nav-num">02</span> Team</a
                    >
                </li>
                <li>
                    <a href="#mods" class="nav-link" data-section="mods"
                        ><span class="nav-num">03</span> Mods</a
                    >
                </li>
                <li>
                    <a href="#docs" class="nav-link" data-section="docs"
                        ><span class="nav-num">04</span> Docs</a
                    >
                </li>
                <li>
                    <a href="#connect" class="nav-link" data-section="connect"
                        ><span class="nav-num">05</span> Connect</a
                    >
                </li>
            </ul>

            <button
                class="nav-hamburger"
                id="navHamburger"
                aria-label="Open navigation"
            >
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M4 6h16"></path><path d="M4 12h16"></path><path
                        d="M4 18h16"></path></svg
                >
            </button>
        </nav>

        <!-- Mobile nav overlay -->
        <div class="mobile-nav" id="mobileNav">
            <a href="#about" class="nav-link" data-section="about"
                ><span class="nav-num">01</span> About</a
            >
            <a href="#team" class="nav-link" data-section="team"
                ><span class="nav-num">02</span> Team</a
            >
            <a href="#mods" class="nav-link" data-section="mods"
                ><span class="nav-num">03</span> Mods</a
            >
            <a href="#docs" class="nav-link" data-section="docs"
                ><span class="nav-num">04</span> Docs</a
            >
            <a href="#connect" class="nav-link" data-section="connect"
                ><span class="nav-num">05</span> Connect</a
            >
        </div>

        <!-- Hero -->
        <header class="hero" id="hero">
            <!-- <div class="hero-badge">
                <span class="hero-badge-dot"></span>
                Minecraft Mod Studio
            </div> -->

            <div class="hero-logo-img">
                <Image
                    src={ambleLogoSvg}
                    alt="AmbleLabs Logo"
                    class="logo-static card-avatar"
                    loading="eager"
                    fetchpriority="high"
                />
                <Image
                    src={ambleLogoGif}
                    alt="AmbleLabs Logo Animated"
                    class="logo-animated card-avatar"
                    loading="lazy"
                />
            </div>

            <h1 class="hero-title">
                <span class="hero-title-glitch">
                    {ASCII}
                </span>
            </h1>

            <p class="hero-tagline">{siteData.description}</p>

            <div class="hero-actions">
                <a
                    href={links.github.url}
                    class="btn btn-ghost"
                    target="_blank"
                    rel="noopener"
                >
                    <Logo
                        icon="github"
                        width={16}
                        height={16}
                        loading="eager"
                    />
                    GitHub
                </a>
                <a
                    href={links.discord.url}
                    class="btn btn-primary"
                    target="_blank"
                    rel="noopener"
                >
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                            d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286z"
                        ></path></svg
                    >
                    Join Discord
                </a>
                <a
                    href={links.codeberg.url}
                    class="btn btn-ghost"
                    target="_blank"
                    rel="noopener"
                >
                    <Logo
                        icon="codeberg"
                        width={16}
                        height={16}
                        loading="eager"
                    />
                    Codeberg
                </a>
            </div>

            <div class="hero-scroll">
                <span class="hero-scroll-text">Scroll</span>
                <div class="hero-scroll-line"></div>
            </div>
        </header>

        <!-- About Section -->
        <section class="section" id="about">
            <div class="animate-on-scroll">
                <span class="section-label">01 // About</span>
                <h2 class="section-title">
                    Building worlds<br />inside worlds.
                </h2>
            </div>

            <div class="about-grid">
                <div class="animate-on-scroll stagger-1">
                    <p class="about-text">{siteData.description}</p>
                    <p class="about-text">
                        From the TARDIS to Stargates, we bring iconic sci-fi
                        universes into Minecraft with detailed, immersive
                        modifications built on Fabric & Forge 1.20+.
                    </p>

                    <div class="about-stats">
                        <div class="stat">
                            <span class="stat-number">{mods.length}</span>
                            <span class="stat-label">Active Projects</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number"
                                >{
                                    members.developers.length +
                                        members.artists.length +
                                        members.junior_developers.length +
                                        members.others.length
                                }</span
                            >
                            <span class="stat-label">Team Members</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number" id="totalDownloads"
                                >--</span
                            >
                            <span class="stat-label"
                                >Downloads (on Modrinth)</span
                            >
                        </div>
                    </div>
                </div>

                <div class="animate-on-scroll stagger-2">
                    <div class="video-container">
                        <div class="video-wrapper">
                            <iframe
                                src={siteData.youtube_embed}
                                title="YouTube video player"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                referrerpolicy="strict-origin-when-cross-origin"
                                allowfullscreen
                                loading="lazy"></iframe>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Team Section -->
        <section class="section" id="team">
            <div class="animate-on-scroll">
                <span class="section-label">02 // Team</span>
                <h2 class="section-title">Meet the crew.</h2>
                <p class="section-desc">
                    The people behind the mods. Developers, artists, and
                    community builders.
                </p>
            </div>

            {
                allMembers.map((group, gi) => (
                    <div
                        class="team-group animate-on-scroll"
                        style={`transition-delay: ${gi * 0.1 + 0.1}s`}
                    >
                        <h3 class="group-label">
                            {group.label}
                            <span class="group-label-count">
                                ({group.list.length})
                            </span>
                        </h3>
                        <div class="card-grid">
                            {group.list.map((m: any, mi: number) => (
                                <div
                                    class="card"
                                    style={`transition-delay: ${mi * 0.04}s`}
                                >
                                    <div class="card-sheen" />
                                    <div class="card-streak" />
                                    <Icon
                                        icon={`team/${m.avatar}`}
                                        alt={m.name}
                                        class="card-avatar"
                                        loading="lazy"
                                        width={64}
                                        height={64}
                                    />
                                    <h4 class="card-name">{m.name}</h4>
                                    {m.role && (
                                        <span class="card-role">{m.role}</span>
                                    )}
                                    {m.link && (
                                        <a
                                            class="card-link"
                                            href={m.link}
                                            target="_blank"
                                            rel="noopener"
                                        >
                                            {m.link
                                                .replace("https://", "")
                                                .replace(/\/$/, "")}{" "}
                                            ↗
                                        </a>
                                    )}
                                    <div class="card-link socials">
                                        {m.socials &&
                                            Object.entries(m.socials).map(
                                                ([type, val]) => (
                                                    <a
                                                        href={val}
                                                        class="social-link"
                                                    >
                                                        <Logo
                                                            icon={type}
                                                            width="24"
                                                            height="24"
                                                            loading="lazy"
                                                        />
                                                    </a>
                                                ),
                                            )}
                                    </div>
                                    <p class="card-quote">"{m.quote}"</p>
                                </div>
                            ))}
                        </div>
                    </div>
                ))
            }
        </section>

        <!-- Mods Section -->
        <section class="section" id="mods">
            <div class="animate-on-scroll">
                <span class="section-label">03 // Mods</span>
                <h2 class="section-title">Our projects.</h2>
                <p class="section-desc">
                    Live stats from Modrinth. Click to explore.
                </p>
            </div>

            <div class="mod-grid animate-on-scroll stagger-1">
                {
                    mods.map((mod: any) => (
                        <a
                            href={`https://modrinth.com/mod/${mod.slug}`}
                            target="_blank"
                            rel="noopener"
                            class="card mod-card"
                            data-slug={mod.slug}
                            style="text-decoration: none;"
                        >
                            <div class="card-sheen" />
                            <div class="card-streak" />
                            <Icon
                                icon={`mod/${mod.slug}.${mod.icon ?? "webp"}`}
                                alt={mod.name}
                                class="card-avatar mod-icon"
                                loading="lazy"
                            />
                            <div class="mod-info">
                                <h4 class="card-name">{mod.name}</h4>
                                <span class="meta">Loading...</span>
                                <p class="card-desc">{mod.description}</p>
                            </div>
                        </a>
                    ))
                }
            </div>
        </section>

        <!-- Docs Section -->
        <section class="section" id="docs">
            <div class="animate-on-scroll">
                <span class="section-label">04 // Docs</span>
                <h2 class="section-title">Wiki & documentation.</h2>
                <p class="section-desc">
                    Guides, API docs, and mod wikis for players and developers.
                </p>
            </div>

            <div class="wiki-list animate-on-scroll stagger-1">
                {
                    wikis.map((w: any) => (
                        <a
                            class="wiki-item"
                            href={w.url}
                            target="_blank"
                            rel="noopener"
                        >
                            <span class="wiki-name">{w.name}</span>
                            <span class="wiki-desc">{w.description}</span>
                            <svg
                                class="wiki-arrow"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <>
                                    <path d="M7 17L17 7" />
                                    <path d="M7 7h10v10" />
                                </>
                            </svg>
                        </a>
                    ))
                }
            </div>
        </section>

        <!-- Connect Section -->
        <section class="section" id="connect">
            <div class="animate-on-scroll">
                <span class="section-label">05 // Connect</span>
                <h2 class="section-title">Find us everywhere.</h2>
            </div>

            <div class="link-grid animate-on-scroll stagger-1">
                {
                    Object.entries(links).map(([icon, link]) => (
                        <a
                            href={link.url}
                            class="link-card social-link"
                            target="_blank"
                            rel="noopener"
                        >
                            <Logo
                                icon={icon}
                                alt={link.name}
                                class="link-icon"
                                loading="lazy"
                            />
                            <span class="link-label">{link.name}</span>
                            {link.description && <span class="link-desc" />}
                        </a>
                    ))
                }
            </div>

            <div class="divider"></div>

            <div class="animate-on-scroll">
                <h3 class="section-sub-heading">Support the Team</h3>
                <p class="section-sub">
                    Feeling generous? Donations help us keep creating.
                </p>
            </div>

            <div class="donate-grid animate-on-scroll stagger-1">
                {
                    donations.map((d: any) => (
                        <a
                            href={d.url}
                            class="donate-card"
                            target="_blank"
                            rel="noopener"
                        >
                            <Logo
                                icon={d.icon}
                                alt={d.platform}
                                class="donate-icon"
                                loading="lazy"
                            />
                            <span class="donate-name">{d.name}</span>
                            <span class="donate-platform">{d.platform}</span>
                        </a>
                    ))
                }
            </div>

            <div class="divider"></div>

            <div class="commissions-block animate-on-scroll">
                <h3 class="section-sub-heading">Commissions</h3>
                <p class="section-sub">
                    Would you like us to make a mod for you?
                </p>
                <a
                    href={siteData.commissions}
                    class="btn btn-primary"
                    target="_blank"
                    rel="noopener">View Commissions Form</a
                >
            </div>
        </section>

        <Footer />

        <!-- Settings hamburger -->
        <button
            id="hamburgerBtn"
            class="hamburger"
            aria-expanded="false"
            aria-controls="settingsMenu"
            aria-label="Open settings"
        >
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
                ></path><circle cx="12" cy="12" r="3"></circle></svg
            >
        </button>

        <div
            id="settingsMenu"
            class="settings-menu"
            role="dialog"
            aria-modal="false"
            hidden
        >
            <div class="settings-panel">
                <header class="settings-header">
                    <h3>Settings</h3>
                    <button
                        id="settingsClose"
                        class="settings-close"
                        aria-label="Close settings">&times;</button
                    >
                </header>
                <div class="settings-body">
                    <div class="setting-row">
                        <label class="setting-label">Card Tilt</label>
                        <label class="switch"
                            ><input id="menuTiltToggle" type="checkbox" /><span
                                class="slider round"></span></label
                        >
                    </div>
                    <div class="setting-row">
                        <label class="setting-label">Saturn Mode</label>
                        <label class="switch"
                            ><input id="saturnToggle" type="checkbox" /><span
                                class="slider round"></span></label
                        >
                    </div>
                    <div class="setting-row">
                        <label class="setting-label"
                            >Party Mode <small class="warn-text"
                                >(EPILEPSY WARNING)</small
                            ></label
                        >
                        <label class="switch"
                            ><input id="partyToggle" type="checkbox" /><span
                                class="slider round"></span></label
                        >
                    </div>
                </div>
                <footer class="settings-footer">
                    <small class="muted">Settings saved to your browser.</small>
                </footer>
            </div>
        </div>

        <!-- Scroll animations + nav highlighting -->
        <script>
            (function () {
                // Scroll-triggered animations
                const observer = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("visible");
                            }
                        });
                    },
                    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
                );

                document
                    .querySelectorAll(".animate-on-scroll")
                    .forEach((el) => observer.observe(el));

                // Active nav link on scroll
                const sections = Array.from(
                    document.querySelectorAll(".section"),
                );
                const navLinks = document.querySelectorAll(".nav-link");
                const nav = document.getElementById("mainNav");

                function updateActiveNav() {
                    const navHeight = nav ? nav.offsetHeight : 80;
                    // The "trigger line" sits just below the nav bar.
                    // The last section whose top is at-or-above this line is the active one.
                    const activeLine = navHeight + 1;
                    let activeId = null;
                    for (let i = sections.length - 1; i >= 0; i--) {
                        if (
                            sections[i].getBoundingClientRect().top <=
                            activeLine
                        ) {
                            activeId = sections[i].id;
                            break;
                        }
                    }
                    navLinks.forEach((link) => {
                        link.classList.toggle(
                            "active",
                            link.dataset.section === activeId,
                        );
                    });
                }

                let navScrollPending = false;
                window.addEventListener(
                    "scroll",
                    () => {
                        if (!navScrollPending) {
                            requestAnimationFrame(() => {
                                updateActiveNav();
                                navScrollPending = false;
                            });
                            navScrollPending = true;
                        }
                    },
                    { passive: true },
                );

                updateActiveNav();

                // Nav scroll background
                window.addEventListener(
                    "scroll",
                    () => {
                        nav.classList.toggle("scrolled", window.scrollY > 50);
                    },
                    { passive: true },
                );

                // Mobile nav toggle
                const hamburger = document.getElementById("navHamburger");
                const mobileNav = document.getElementById("mobileNav");
                if (hamburger && mobileNav) {
                    hamburger.addEventListener("click", () => {
                        mobileNav.classList.toggle("open");
                    });
                    mobileNav.querySelectorAll(".nav-link").forEach((link) => {
                        link.addEventListener("click", () =>
                            mobileNav.classList.remove("open"),
                        );
                    });
                }

                // Total downloads counter
                const totalEl = document.getElementById("totalDownloads");
                if (totalEl) {
                    const CACHE_KEY = "amble_mods_cache_v1";
                    try {
                        const raw = localStorage.getItem(CACHE_KEY);
                        if (raw) {
                            const cache = JSON.parse(raw);
                            let total = 0;
                            for (const slug in cache) {
                                if (cache[slug].downloads)
                                    total += cache[slug].downloads;
                            }
                            if (total > 0) {
                                totalEl.textContent =
                                    total >= 1000
                                        ? (total / 1000).toFixed(1) + "k"
                                        : String(total);
                            }
                        }
                    } catch (e) {}
                    // Will be updated after mods.js runs
                    window._updateTotalDownloads = function (total) {
                        if (total > 0) {
                            totalEl.textContent =
                                total >= 1000
                                    ? (total / 1000).toFixed(1) + "k"
                                    : String(total);
                        }
                    };
                }
            })();
        </script>

        <!-- Tilt script -->
        <script src="../js/tilt.js"></script>
        <!-- Settings logic -->
        <script src="../js/settings.js"></script>
        <!-- Mods data -->
        <script src="../js/mods.js"></script>
    </body>
</html>
