---
import '../assets/style.css';
import Footer from '../components/Footer.astro';
import siteData from '../data/site.json';

const { members, mods, wikis, links, donations } = siteData;
const allMembers = [
  { label: 'Developers', list: members.developers },
  { label: 'Junior Developers', list: members.junior_developers },
  { label: 'Artists', list: members.artists },
  { label: 'Others', list: members.others },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AmbleLabs</title>
    <meta content="AmbleLabs" property="og:title" />
    <meta content={siteData.tagline} property="og:description" />
    <meta content="https://amblelabs.github.io" property="og:url" />
    <meta content="https://amblelabs.github.io/img/amblelabs_icon.gif" property="og:image" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg" href="/img/amblelabs_icon.svg" />
    <meta content="#F69602" data-react-helmet="true" name="theme-color" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Nunito+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- Animated background -->
    <div class="bg-effects" aria-hidden="true">
      <div class="bg-orb bg-orb--1"></div>
      <div class="bg-orb bg-orb--2"></div>
      <div class="bg-orb bg-orb--3"></div>
      <div class="bg-grid"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <!-- Hero -->
    <header class="hero">
      <div class="hero-logo">
        <img src="/img/amblelabs_icon.svg" alt="AmbleLabs Logo" class="logo-static" />
        <img src="/img/amblelabs_icon.gif" alt="AmbleLabs Logo Animated" class="logo-animated" />
      </div>
      <h1 class="hero-title">AmbleLabs</h1>
      <p class="hero-tagline">{siteData.description}</p>
    </header>

    <!-- Navigation -->
    <nav class="nav" id="mainNav">
      <button class="nav-btn active" data-tab="home">Home</button>
      <button class="nav-btn" data-tab="members">Members</button>
      <button class="nav-btn" data-tab="mods">Mods</button>
      <button class="nav-btn" data-tab="wikis">Wikis</button>
      <button class="nav-btn" data-tab="links">Links</button>
    </nav>

    <!-- Main content area -->
    <main class="content">

      <!-- HOME -->
      <section class="tab-panel active" id="tab-home">
        <div class="home-section">
          <img src="/img/amblelabs_text.svg" alt="AmbleLabs" class="home-wordmark" />
          <p class="home-desc">{siteData.description}</p>
          <div class="video-wrapper">
            <iframe
              src={siteData.youtube_embed}
              title="YouTube video player"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </section>

      <!-- MEMBERS -->
      <section class="tab-panel" id="tab-members">
        <h2 class="section-heading">Meet the Team</h2>
        <p class="section-sub">The amazing people who develop our mods.</p>

        {allMembers.map(group => (
          <div class="member-group">
            <h3 class="group-label">{group.label}</h3>
            <div class="card-grid">
              {group.list.map((m: any) => (
                <div class="card">
                  <img src={m.avatar} alt={m.name} class="card-avatar" />
                  <h4 class="card-name">{m.name}</h4>
                  {m.role && <span class="card-role">{m.role}</span>}
                  {m.link && (
                    <a class="card-link" href={m.link} target="_blank" rel="noopener">
                      {m.link.replace('https://', '').replace(/\/$/, '')}
                    </a>
                  )}
                  <p class="card-quote">"{m.quote}"</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </section>

      <!-- MODS -->
      <section class="tab-panel" id="tab-mods">
        <h2 class="section-heading">Our Mods</h2>
        <p class="section-sub">Live stats populated from Modrinth.</p>

        <div class="mod-grid">
          {mods.map((mod: any) => (
            <div class="card mod-card" data-slug={mod.slug}>
              <img src={mod.icon} alt={mod.name} class="card-avatar mod-icon" />
              <div class="mod-info">
                <h4 class="card-name">{mod.name}</h4>
                <a class="card-link" href={mod.url} target="_blank" rel="noopener">
                  {mod.url.replace('https://', '')}
                </a>
                <span class="meta">Loading...</span>
                <p class="card-desc">{mod.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- WIKIS -->
      <section class="tab-panel" id="tab-wikis">
        <h2 class="section-heading">Wiki & Documentation</h2>
        <p class="section-sub">Useful links to documentation, guides and mod wikis.</p>

        <div class="wiki-list">
          {wikis.map((w: any) => (
            <a class="wiki-item" href={w.url} target="_blank" rel="noopener">
              <span class="wiki-name">{w.name}</span>
              <span class="wiki-desc">{w.description}</span>
              <svg class="wiki-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          ))}
        </div>
      </section>

      <!-- LINKS -->
      <section class="tab-panel" id="tab-links">
        <h2 class="section-heading">Connect With Us</h2>

        <div class="link-grid">
          <a href={links.discord} class="link-card" target="_blank" rel="noopener">
            <img src="/img/discord_logo.svg" alt="Discord" class="link-icon" />
            <span class="link-label">Discord</span>
            <span class="link-desc">Join our community</span>
          </a>
          <a href={links.github} class="link-card" target="_blank" rel="noopener">
            <img src="/img/github_logo.svg" alt="GitHub" class="link-icon" />
            <span class="link-label">GitHub</span>
            <span class="link-desc">Open source projects</span>
          </a>
          <a href={links.modrinth} class="link-card" target="_blank" rel="noopener">
            <img src="/img/modrinth_logo.svg" alt="Modrinth" class="link-icon" />
            <span class="link-label">Modrinth</span>
            <span class="link-desc">Browse our mods</span>
          </a>
          <a href={links.youtube} class="link-card" target="_blank" rel="noopener">
            <img src="/img/youtube_logo.svg" alt="YouTube" class="link-icon" />
            <span class="link-label">YouTube</span>
            <span class="link-desc">Watch our videos</span>
          </a>
        </div>

        <div class="divider"></div>

        <h3 class="section-sub-heading">Support the Team</h3>
        <p class="section-sub">Feeling generous? Donations help us keep creating.</p>

        <div class="donate-grid">
          {donations.map((d: any) => (
            <a href={d.url} class="donate-card" target="_blank" rel="noopener">
              <img src={`/img/${d.icon === 'kofi' ? 'kofi' : 'boosty'}_logo.svg`} alt={d.platform} class="donate-icon" />
              <span class="donate-name">{d.name}</span>
              <span class="donate-platform">{d.platform}</span>
            </a>
          ))}
        </div>

        <div class="divider"></div>

        <div class="commissions-block">
          <h3 class="section-sub-heading">Commissions</h3>
          <p class="section-sub">Would you like us to make a mod for you?</p>
          <a href={links.commissions} class="btn-primary" target="_blank" rel="noopener">View Commissions Form</a>
        </div>
      </section>
    </main>

    <Footer />

    <!-- Settings hamburger -->
    <button id="hamburgerBtn" class="hamburger" aria-expanded="false" aria-controls="settingsMenu" aria-label="Open settings">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/></svg>
    </button>

    <div id="settingsMenu" class="settings-menu" role="dialog" aria-modal="false" hidden>
      <div class="settings-panel">
        <header class="settings-header">
          <h3>Settings</h3>
          <button id="settingsClose" class="settings-close" aria-label="Close settings">&times;</button>
        </header>
        <div class="settings-body">
          <div class="setting-row">
            <label class="setting-label">Tilt</label>
            <label class="switch"><input id="menuTiltToggle" type="checkbox"><span class="slider round"></span></label>
          </div>
          <div class="setting-row">
            <label class="setting-label">Saturn Mode</label>
            <label class="switch"><input id="saturnToggle" type="checkbox"><span class="slider round"></span></label>
          </div>
          <div class="setting-row">
            <label class="setting-label">Party Mode <small class="warn-text">(EPILEPSY WARNING)</small></label>
            <label class="switch"><input id="partyToggle" type="checkbox"><span class="slider round"></span></label>
          </div>
        </div>
        <footer class="settings-footer">
          <small class="muted">Settings saved to your browser.</small>
        </footer>
      </div>
    </div>

    <!-- Tab navigation script -->
    <script is:inline>
      (function() {
        const btns = document.querySelectorAll('.nav-btn');
        const panels = document.querySelectorAll('.tab-panel');

        function switchTab(tabId) {
          btns.forEach(b => b.classList.toggle('active', b.dataset.tab === tabId));
          panels.forEach(p => {
            const isActive = p.id === 'tab-' + tabId;
            p.classList.toggle('active', isActive);
          });
        }

        btns.forEach(btn => {
          btn.addEventListener('click', () => switchTab(btn.dataset.tab));
        });
      })();
    </script>

    <!-- Tilt script -->
    <script src="../js/tilt.js"></script>
    <!-- Settings logic -->
    <script src="../js/settings.js"></script>
    <!-- Mods data -->
    <script src="../js/mods.js"></script>
  </body>
</html>
