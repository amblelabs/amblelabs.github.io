---
import type { HTMLAttributes } from "astro/types";
import { Image } from "astro:assets";

type ImgAttributes = Omit<HTMLAttributes<"img">, "src" | "width" | "height">;

type Props = {
    icon: string;
    width?: number;
    height?: number;
} & ImgAttributes;

const icon = `/src/assets/icon/${Astro.props.icon}`;

const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/icon/**/*.{jpeg,jpg,png,webp,gif,svg}",
);

if (!images[icon])
    throw new Error(
        `"${icon}" does not exist in glob: "src/assets/icon/*.{jpeg,jpg,png,webp,gif,svg}"`,
    );
---

<Image alt={icon} {...Astro.props} src={images[icon]()} />
